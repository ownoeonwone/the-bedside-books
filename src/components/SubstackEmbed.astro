---
interface Props {
  publication?: string;
}
const { publication = "thebedsidebooks" } = Astro.props;
const action = `https://${publication}.substack.com/api/v1/free?nojs=true`;
---

<form class="signup-form" action={action} method="post">
  <label class="sr-only" for="signup-email">Email address</label>
  <input
    id="signup-email"
    class="signup-input"
    type="email"
    name="email"
    inputmode="email"
    autocomplete="email"
    placeholder="your@email.com"
    required
  />
  <input type="hidden" name="first_url" value="https://thebedsidebooks.com/" />
  <input type="hidden" name="first_referrer" value="" />
  <input type="hidden" name="current_url" value="https://thebedsidebooks.com/" />
  <input type="hidden" name="current_referrer" value="" />
  <input type="hidden" name="referral_code" value="" />
  <input type="hidden" name="source" value="embed" />
  <button class="signup-button" type="submit">Join the list</button>
</form>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
