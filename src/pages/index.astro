---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import SubstackEmbed from "../components/SubstackEmbed.astro";
import cover from "../assets/the-truth-about-the-puppy-cover.png";
---

<Base
  title="The Bedside Books · Honest books for honest families"
  description="An independent publishing imprint. First book: The Truth About the Puppy by Dr. Jay, coming 2026."
>
  <main class="container-prose py-14 sm:py-20">

    <!-- Hero -->
    <section class="text-center">
      <img
        src="/logo.svg"
        alt="The Bedside Books"
        width="1400"
        height="280"
        class="mx-auto w-full max-w-md sm:max-w-lg h-auto"
      />
      <p class="mt-7 sm:mt-9 text-2xl sm:text-3xl italic leading-snug">
        Honest books for honest families.
      </p>
    </section>

    <div class="rule mt-16 sm:mt-20"></div>

    <!-- First Book -->
    <section class="mt-16 sm:mt-20 text-center">
      <p class="section-eyebrow text-lg sm:text-xl">Our first book</p>

      <div class="mt-8 sm:mt-10">
        <Image
          src={cover}
          alt="Cover of The Truth About the Puppy, an illustrated picture book"
          widths={[400, 600, 900]}
          sizes="(max-width: 640px) 88vw, 560px"
          formats={["webp"]}
          quality={80}
          class="mx-auto w-full max-w-[560px] h-auto rounded-[2px] cover-shadow"
        />
      </div>

      <h1 class="mt-8 sm:mt-10 text-4xl sm:text-5xl leading-tight">
        The Truth About the Puppy
      </h1>
      <p class="mt-2 text-lg sm:text-xl italic" style="color: color-mix(in srgb, var(--color-ink) 75%, transparent);">
        an honest picture book for begging children and tired parents
      </p>
      <p class="mt-3 text-base sm:text-lg">
        by Dr. Jay
      </p>

      <blockquote class="pullquote mt-10 sm:mt-12 mx-auto max-w-[28rem] text-xl sm:text-2xl">
        <p>You asked for a puppy.<br>You begged and you cried.</p>
        <p class="mt-2">You promised you&rsquo;d walk her.<br>You promised. You lied.</p>
      </blockquote>

      <p class="mt-10 sm:mt-12 text-lg sm:text-xl leading-[1.6] text-left mx-auto max-w-[34rem]">
        A picture book that tells the truth about getting a dog: the chewed shoes,
        the early-morning walks, the years of love, and the long goodbye at the end.
        For the family who has asked, for the family who is about to, and for the family
        who has loved a dog all the way through.
      </p>

      <p class="mt-8 text-base sm:text-lg section-eyebrow">
        Coming 2026
      </p>
    </section>

    <div class="rule mt-16 sm:mt-20"></div>

    <!-- Signup -->
    <section class="mt-16 sm:mt-20 text-center">
      <h2 class="text-3xl sm:text-4xl leading-tight">Hear about it first</h2>
      <p class="mt-4 text-lg sm:text-xl leading-[1.6] mx-auto max-w-[32rem]">
        We publish one or two books a year. Join the list to hear about new releases,
        see early previews, and find out when <em>The Truth About the Puppy</em> is available.
      </p>
      <div class="mt-8">
        <SubstackEmbed />
      </div>
      <p class="mt-3 text-sm" style="color: color-mix(in srgb, var(--color-ink) 55%, transparent);">
        We send a note when there is something worth saying. Never more often than that.
      </p>
    </section>

    <div class="rule mt-16 sm:mt-20"></div>

    <!-- Footer -->
    <footer class="mt-12 sm:mt-14 text-center">
      <p class="text-sm sm:text-base" style="color: color-mix(in srgb, var(--color-ink) 70%, transparent);">
        The Bedside Books &middot; Greenville, South Carolina &middot;
        <a href="mailto:jay@thebedsidebooks.com">jay@thebedsidebooks.com</a>
      </p>
      <p class="mt-3 text-xs sm:text-sm" style="color: color-mix(in srgb, var(--color-ink) 50%, transparent);">
        &copy; 2026 The Bedside Books
      </p>
    </footer>

  </main>
</Base>
