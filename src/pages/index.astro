---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import SubstackEmbed from "../components/SubstackEmbed.astro";

import cover from "../assets/the-truth-about-the-puppy-cover.png";
import colophon from "../assets/colophon-mark.png";
import spread7 from "../assets/spread-7-dad-and-adult-penny.png";
import spread9 from "../assets/spread-9-dad-and-elder-penny.png";
import spread10 from "../assets/spread-10-planting-tree.png";
---

<Base
  title="The Bedside Books · Honest books for honest families"
  description="An independent publishing imprint. First book: The Truth About the Puppy by Dr. Jay, coming 2026."
>
  <main>

    <!-- Hero — colophon mark above the wordmark, matching the imprint mark on the book jacket. -->
    <section class="container-prose pt-16 sm:pt-24 text-center">
      <Image
        src={colophon}
        alt=""
        widths={[180, 280, 420]}
        sizes="(max-width: 640px) 140px, 180px"
        formats={["webp"]}
        quality={90}
        class="mx-auto h-36 sm:h-44 w-auto"
        aria-hidden="true"
      />
      <h1 class="mt-5 sm:mt-6 wordmark text-xl sm:text-2xl">
        The Bedside Books
      </h1>
      <p class="mt-8 sm:mt-10 text-2xl sm:text-3xl italic leading-snug">
        Honest books for honest families.
      </p>
    </section>

    <div class="rule mt-16 sm:mt-20"></div>

    <!-- Imprint statement -->
    <section class="container-prose mt-16 sm:mt-20 text-center">
      <p class="imprint-statement">
        The Bedside Books is an independent publishing imprint creating honest
        books across two lines: picture books for children that tell the truth
        about growing up, and physician-authored books for adults that tell the
        truth about being well.
      </p>
    </section>

    <div class="rule mt-16 sm:mt-20"></div>

    <!-- First Book -->
    <section class="container-wide mt-16 sm:mt-20 text-center">
      <p class="section-eyebrow text-lg sm:text-xl">Our first book</p>

      <div class="mt-10 sm:mt-14">
        <Image
          src={cover}
          alt="Cover of The Truth About the Puppy, an illustrated picture book"
          widths={[480, 720, 960, 1280]}
          sizes="(max-width: 640px) 92vw, (max-width: 896px) 80vw, 720px"
          formats={["webp"]}
          quality={82}
          class="mx-auto w-full max-w-[720px] h-auto rounded-[2px] cover-shadow"
        />
      </div>

      <!-- Title, subtitle, byline, and imprint mark are baked into the cover
           image, so we skip them here and go straight to the verse. -->
      <div class="container-prose">
        <figure class="mt-14 sm:mt-20 mx-auto max-w-[30rem]">
          <div aria-hidden="true" class="flex justify-center mb-5">
            <span class="verse-ornament"></span>
          </div>
          <blockquote class="verse text-xl sm:text-2xl text-center">
            <p>&ldquo;You asked for a puppy.<br>You begged and you cried.</p>
            <p class="mt-3">You promised you&rsquo;d walk her.<br>You promised. You lied.&rdquo;</p>
          </blockquote>
          <div aria-hidden="true" class="flex justify-center mt-5">
            <span class="verse-ornament"></span>
          </div>
        </figure>

        <p class="mt-12 sm:mt-14 text-lg sm:text-xl text-left mx-auto max-w-[34rem]">
          A picture book that tells the truth about getting a dog: the chewed
          shoes, the early-morning walks, the years of love, and the long
          goodbye at the end. For the family who has asked, for the family who
          is about to, and for the family who has loved a dog all the way
          through.
        </p>

        <p class="mt-10 text-base sm:text-lg section-eyebrow">
          Coming 2026
        </p>
      </div>
    </section>

    <div class="rule mt-20 sm:mt-28"></div>

    <!-- A look inside -->
    <section class="container-wide mt-20 sm:mt-28 text-center">
      <p class="section-eyebrow text-lg sm:text-xl">A look inside</p>

      <div class="mt-10 sm:mt-14">
        <Image
          src={spread7}
          alt="Interior spread: a father sits in a kitchen chair with an adult golden retriever resting against his leg, his hand on her head"
          widths={[640, 960, 1280]}
          sizes="(max-width: 640px) 92vw, (max-width: 896px) 86vw, 800px"
          formats={["webp"]}
          quality={82}
          class="mx-auto w-full max-w-[800px] h-auto rounded-[2px] spread-shadow"
        />
      </div>

      <div class="mt-8 sm:mt-12 grid gap-8 sm:gap-10 sm:grid-cols-2 max-w-[820px] mx-auto">
        <Image
          src={spread9}
          alt="Interior spread: a father carries an aging Penny down a staircase"
          widths={[420, 640, 840]}
          sizes="(max-width: 640px) 92vw, 400px"
          formats={["webp"]}
          quality={82}
          class="w-full h-auto rounded-[2px] spread-shadow"
        />
        <Image
          src={spread10}
          alt="Interior spread: a family kneels in a field, planting a young tree"
          widths={[420, 640, 840]}
          sizes="(max-width: 640px) 92vw, 400px"
          formats={["webp"]}
          quality={82}
          class="w-full h-auto rounded-[2px] spread-shadow"
        />
      </div>
    </section>

    <div class="rule mt-20 sm:mt-28"></div>

    <!-- Signup -->
    <section class="container-prose mt-20 sm:mt-28 text-center">
      <h2 class="text-3xl sm:text-4xl leading-[1.15]">Hear about it first</h2>
      <p class="mt-5 text-lg sm:text-xl mx-auto max-w-[32rem]">
        We publish one or two books a year. Join the list to hear about new
        releases, see early previews, and find out when
        <em>The Truth About the Puppy</em> is available.
      </p>
      <div class="mt-9">
        <SubstackEmbed />
      </div>
      <p class="mt-3 text-sm" style="color: color-mix(in srgb, var(--color-ink) 55%, transparent);">
        We send a note when there is something worth saying. Never more often than that.
      </p>
    </section>

    <div class="rule mt-20 sm:mt-28"></div>

    <!-- About -->
    <section class="container-prose mt-20 sm:mt-28 text-center">
      <h2 class="text-3xl sm:text-4xl leading-[1.15]">About The Bedside Books</h2>

      <div class="mt-8 text-left text-lg sm:text-xl">
        <p>
          The Bedside Books is an independent publishing imprint founded in
          2026. We publish two lines of books: picture books for children, and
          health books written by practicing physicians. What unites them is a
          single promise: real wisdom, delivered the way a good doctor or a
          thoughtful parent would deliver it. Honestly, intimately, without
          unnecessary medicalization or sweetening.
        </p>
        <p class="mt-5">
          Our first book, <em>The Truth About the Puppy</em>, arrives in 2026.
          More are in development.
        </p>
      </div>

      <p class="mt-10 text-base sm:text-lg" style="color: color-mix(in srgb, var(--color-ink) 70%, transparent);">
        Founder: Dr. Jay &middot; Greenville, South Carolina
      </p>
      <p class="mt-3 text-base sm:text-lg" style="color: color-mix(in srgb, var(--color-ink) 70%, transparent);">
        Read our writing on <a href="https://thebedsidebooks.substack.com">Substack</a>.
      </p>
    </section>

    <div class="rule mt-20 sm:mt-28"></div>

    <!-- Footer -->
    <footer class="container-prose mt-12 sm:mt-16 pb-16 sm:pb-24 text-center">
      <p class="text-sm sm:text-base" style="color: color-mix(in srgb, var(--color-ink) 70%, transparent);">
        <span class="smallcaps">The Bedside Books</span>
        <span class="mx-3" aria-hidden="true">&middot;</span>
        Greenville, South Carolina
        <span class="mx-3" aria-hidden="true">&middot;</span>
        <!--email_off--><a href="mailto:jay&#64;thebedsidebooks.com">jay&#64;thebedsidebooks.com</a><!--/email_off-->
      </p>
      <p class="mt-3 text-xs sm:text-sm" style="color: color-mix(in srgb, var(--color-ink) 42%, transparent);">
        &copy; 2026 The Bedside Books
      </p>
    </footer>

  </main>
</Base>
